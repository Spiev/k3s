# Restic backup configuration for k3s cluster.
# Copy to .restic.env and set permissions:
#   cp .restic.env.example .restic.env && chmod 600 .restic.env

# ── MQTT ──────────────────────────────────────────────────────────────────────
export MQTT_HOST="localhost"           # Home Assistant / Mosquitto host
export MQTT_PORT="1883"

# ── Staging ───────────────────────────────────────────────────────────────────
# Temporary directory for DB dumps and kubectl cp output.
# Needs enough free space for the largest DB dump + media export.
# Cleaned up automatically after each backup run.
export BACKUP_TEMP_DIR="/tmp/k3s-backup"

# ── Services ──────────────────────────────────────────────────────────────────
# Space-separated list of services to back up.
# Add a service here as soon as it is migrated to k3s.
# Supported values: paperless teslamate
export BACKUP_SERVICES="paperless teslamate"

# ── S3 Offsite Backup (Hetzner Object Storage) ────────────────────────────────
# Initialize once before first use:
#   source .restic.env
#   RESTIC_PASSWORD="$RESTIC_PASSWORD_S3" restic -r "$RESTIC_REPO_S3" init
export AWS_ACCESS_KEY_ID="YOUR_HETZNER_S3_ACCESS_KEY_ID"
export AWS_SECRET_ACCESS_KEY="YOUR_HETZNER_S3_SECRET_ACCESS_KEY"
# e.g. s3:https://nbg1.your-objectstorage.com/my-backup-bucket/restic-repo
export RESTIC_REPO_S3="s3:https://YOUR_REGION.your-objectstorage.com/YOUR_BUCKET/restic-repo"
export RESTIC_PASSWORD_S3="YOUR_S3_REPO_PASSWORD"
