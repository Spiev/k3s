apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: paperless
  namespace: paperless
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
spec:
  ingressClassName: traefik
  rules:
    - host: paperless.fritz.box
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: paperless-webserver
                port:
                  number: 8000
