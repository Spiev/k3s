apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: moto-tracker-grafana
  namespace: moto-tracker
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
spec:
  ingressClassName: traefik
  rules:
    - host: motomon.fritz.box
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: moto-tracker-grafana
                port:
                  number: 3000
