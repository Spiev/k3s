# Template. Copy to moto-tracker-secrets.sops.yaml, fill in real values, then:
#   sops --encrypt --in-place apps/moto-tracker/moto-tracker-secrets.sops.yaml
apiVersion: v1
kind: Secret
metadata:
  name: moto-tracker-secrets
  namespace: moto-tracker
  labels:
    app: moto-tracker
    managed-by: flux
stringData:
  # Postgres password (used by the DB, the tracker, and the Grafana datasource).
  DATABASE_PASS: changeme
  # Home Assistant base URL — the node address, since HA runs in Docker (not k3s).
  HA_URL: http://192.168.1.10:8123
  # Home Assistant long-lived access token (see moto-tracker docs/ha-setup.md).
  HA_TOKEN: changeme
  # Public URL of the tracker web UI — used to render shareable tour links.
  PUBLIC_BASE_URL: https://moto.fritz.box
  # Grafana admin password (anonymous viewing is enabled; admin is for editing).
  GRAFANA_ADMIN_PASSWORD: changeme
