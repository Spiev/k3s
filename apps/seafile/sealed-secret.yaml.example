# DIESE DATEI IST NUR EIN TEMPLATE — nicht direkt anwenden!
#
# Das echte sealed-secret.yaml muss mit kubeseal generiert werden:
#
#   kubectl create secret generic seafile-secrets \
#     --namespace seafile \
#     --from-literal=MYSQL_ROOT_PASSWORD=<passwort> \
#     --from-literal=MYSQL_PASSWORD=<passwort> \
#     --from-literal=SEAFILE_ADMIN_PASSWORD=<passwort> \
#     --from-literal=SECRET_KEY=$(openssl rand -hex 32) \
#     --dry-run=client -o yaml | \
#     kubeseal --format yaml > apps/seafile/sealed-secret.yaml
#
# Das resultierende sealed-secret.yaml kann sicher ins Git-Repo committed werden.
# Nur der Cluster kann es entschlüsseln.
#
# Struktur des generierten SealedSecret (zur Referenz):
---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: seafile-secrets
  namespace: seafile
spec:
  encryptedData:
    MYSQL_ROOT_PASSWORD: <encrypted>
    MYSQL_PASSWORD: <encrypted>
    SEAFILE_ADMIN_PASSWORD: <encrypted>
    SECRET_KEY: <encrypted>
