# Kopiere diese Datei nach ingress-patch.yaml und trage deine echte Domain ein.
# ingress-patch.yaml ist in .gitignore und kommt nicht ins Repo.
#
#   cp ingress-patch.yaml.example ingress-patch.yaml
#
# JSON Patch: ersetzt nur den Host-Wert — paths und alles andere
# kommen unverändert aus base/ingress.yaml.
- op: replace
  path: /spec/rules/0/host
  value: seafile.deine-domain.de    # <-- echte Domain eintragen
