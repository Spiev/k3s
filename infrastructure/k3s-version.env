# Pinned k3s version — Renovate tracks this for update notifications.
#
# This file is a shell-sourceable env file: source it and the installer
# picks up the version automatically — no need to copy the number by hand.
#
# Upgrade on the server node (run from the repo root):
#   source infrastructure/k3s-version.env
#   curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION="$K3S_VERSION" sh -
#
# Verify afterwards:
#   k3s --version
#   kubectl get nodes
#   kubectl get pods -A

K3S_VERSION=v1.36.2+k3s1
